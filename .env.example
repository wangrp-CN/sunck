# 涉铁工程智能监控平台 —— 环境变量模板
# 用法：cp .env.example .env && 填写真实值。.env 已被 .gitignore 忽略，严禁提交到仓库。
# 生产部署前务必逐项替换占位符，尤其是 SECRET_KEY / 各组件密码。

# ---------- 应用 ----------
APP_NAME=涉铁工程智能监控平台
APP_ENV=production
DEBUG=false
HOST=0.0.0.0
PORT=8000
# ⚠️ 生产必须替换为强随机值：python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440
LOG_LEVEL=INFO
# ⚠️ 生产环境务必改为前端正式域名，禁止 * ：例如 https://rail.example.com
CORS_ORIGINS=*

# ---------- PostgreSQL ----------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=rail_monitor
POSTGRES_USER=rail_monitor
POSTGRES_PASSWORD=

# ---------- Redis ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# 若应用直接读取 REDIS_URL（config 默认按 host/port/password 自动拼接，可留空），请保持与 REDIS_PASSWORD 一致
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379/0

# ---------- MQTT (Mosquitto) ----------
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
# 生产建议开启认证，留空表示匿名（仅限内网隔离环境）
MQTT_USERNAME=
MQTT_PASSWORD=

# ---------- MinIO 对象存储 ----------
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=rail-monitor
# 走 HTTPS 时改为 true（配合反向代理或 MinIO 自带 TLS）
MINIO_SECURE=false

# ---------- 高德地图 Web 服务 ----------
AMAP_WEB_KEY=

# ---------- Celery ----------
CELERY_BROKER_URL=redis://:CHANGE_ME@127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@127.0.0.1:6379/2
