# 涉铁工程智能监控平台 —— 环境变量模板
# 复制为 .env 并填入实际值（.env 已被 .gitignore 忽略，请勿提交真实密钥）

# ---------- 应用 ----------
APP_NAME=涉铁工程智能监控平台
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- PostgreSQL ----------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=rail_monitor
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev123
# 由上面的变量拼出（也可直接写全串）
DATABASE_URL=postgresql+psycopg2://dev:dev123@127.0.0.1:5432/rail_monitor

# ---------- Redis ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=dev_local_redis
REDIS_URL=redis://:dev_local_redis@127.0.0.1:6379/0

# ---------- MQTT (Mosquitto 原生，匿名可连) ----------
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_USERNAME=
MQTT_PASSWORD=

# ---------- MinIO 对象存储 ----------
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rail-monitor
MINIO_SECURE=false

# ---------- 高德地图 Web 服务 ----------
AMAP_WEB_KEY=your-amap-web-service-key

# ---------- Celery（以原生 Redis 作为 broker/backend） ----------
CELERY_BROKER_URL=redis://:dev_local_redis@127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://:dev_local_redis@127.0.0.1:6379/2
